@page
@model LoginModel
@{
    ViewData["Title"] = "Вход";
}

<h1 class="text-heading">@ViewData["Title"]</h1>
<div class="row">
    <div class="col-md-5 col-lg-4">
        <section class="pfn-card p-4">
            <form id="account" method="post">
                <h2 class="h5 mb-3">Войдите с учётной записью приложения</h2>
                <hr class="border-accent opacity-25" />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label">Электронная почта</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="пароль" />
                    <label asp-for="Input.Password" class="form-label">Пароль</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="checkbox mb-3">
                    <label asp-for="Input.RememberMe" class="form-label d-flex align-items-center gap-2">
                        <input class="form-check-input m-0" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-pfn">Войти</button>
                </div>
                <div class="mt-3 small">
                    <p class="mb-2">
                        <a id="forgot-password" asp-page="./ForgotPassword">Забыли пароль?</a>
                    </p>
                    <p class="mb-2">
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Регистрация нового пользователя</a>
                    </p>
                    <p class="mb-0">
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Отправить письмо подтверждения ещё раз</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
    <div class="col-md-6 col-lg-7 offset-md-1 mt-4 mt-md-0">
        <section class="pfn-card p-4 h-100">
            <h2 class="h5 mb-3">Вход через внешний сервис</h2>
            <hr class="border-accent opacity-25" />
            @if ((Model.ExternalLogins?.Count ?? 0) == 0)
            {
                <p class="mb-0 text-muted">
                    Внешние способы входа не настроены. Подробнее о подключении внешней аутентификации см.
                    <a href="https://go.microsoft.com/fwlink/?LinkID=532715" rel="noopener noreferrer">в документации ASP.NET</a>.
                </p>
            }
            else
            {
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <p>
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="btn btn-outline-accent me-2 mb-2" name="provider" value="@provider.Name" title="Войти через @provider.DisplayName">@provider.DisplayName</button>
                        }
                    </p>
                </form>
            }
        </section>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}
