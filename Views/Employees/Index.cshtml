@model List<Employee>
@{
    ViewData["Title"] = "Сотрудники";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h1 class="mb-0">Сотрудники</h1>
    <a class="btn btn-pfn" asp-action="Create">Добавить</a>
</div>

<form method="get" class="pfn-card p-3 mb-4 d-flex flex-wrap gap-2 align-items-end">
    <div>
        <label class="form-label small mb-0">Отдел</label>
        <select name="departmentId" class="form-select" asp-items="ViewBag.Departments">
            <option value="">Все отделы</option>
        </select>
    </div>
    <div class="flex-grow-1" style="min-width:200px">
        <label class="form-label small mb-0">Поиск ФИО / должность</label>
        <input name="search" value="@ViewBag.Search" class="form-control" />
    </div>
    <button type="submit" class="btn btn-gradient">Найти</button>
</form>

<div class="table-responsive table-pfn">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>ФИО</th>
                <th>Отдел</th>
                <th>Должность</th>
                <th>График</th>
                <th>Ставка</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.FullName</td>
                <td>@e.Department.Name</td>
                <td>@e.Position</td>
                <td>@e.WorkScheduleType</td>
                <td>@e.HourlyRate.ToString("0.##") ₽</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-gradient" asp-action="Edit" asp-route-id="@e.Id">Изменить</a>
                    <form asp-action="Delete" asp-route-id="@e.Id" method="post" class="d-inline" onsubmit="return confirm('Удалить сотрудника?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3">Удалить</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
